# ── Required ──────────────────────────────────────────────────────────────────

# Your Anthropic API key (or OpenAI if using that provider)
SEC_RAG_ANTHROPIC_API_KEY=sk-ant-...
# SEC_RAG_OPENAI_API_KEY=sk-...
# SEC_RAG_LLM_PROVIDER=anthropic          # "anthropic" or "openai"
# SEC_RAG_LLM_MODEL=claude-sonnet-4-20250514

# ── Qdrant (vector database) ─────────────────────────────────────────────────

# SEC_RAG_QDRANT_URL=http://localhost:6333   # default; Docker overrides to http://qdrant:6333
# SEC_RAG_QDRANT_COLLECTION=employment_contracts
# SEC_RAG_QDRANT_API_KEY=                    # set only if Qdrant has auth enabled

# ── Embeddings ────────────────────────────────────────────────────────────────

# SEC_RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2   # dense embedding model (sentence-transformers)

# ── EDGAR (SEC filing source) ─────────────────────────────────────────────────

# SEC requires a User-Agent with your name + email for EDGAR API access
# SEC_RAG_EDGAR_USER_AGENT=YourName Research your-email@example.com

# ── API protection ────────────────────────────────────────────────────────────

# If set, clients must send X-API-Key header on every request. Empty = no auth.
# SEC_RAG_API_KEY=
# SEC_RAG_QUERY_TIMEOUT_SECONDS=120

# Set to true when behind a reverse proxy (nginx, ALB) to read client IP from X-Forwarded-For
# SEC_RAG_BEHIND_PROXY=false

# ── Logging ───────────────────────────────────────────────────────────────────

# "console" for local dev (colored, human-readable), "json" for production (ELK/Datadog)
# SEC_RAG_LOG_FORMAT=console
# SEC_RAG_LOG_LEVEL=INFO

# ── Redis caching (optional) ─────────────────────────────────────────────────

# Caches query responses to avoid repeat LLM calls. Disabled if URL is empty.
# Docker overrides to redis://redis:6379/0
# SEC_RAG_REDIS_URL=
# SEC_RAG_CACHE_TTL_SECONDS=3600             # 1 hour default
# SEC_RAG_CACHE_ENABLED=true

# ── Langfuse observability (optional) ─────────────────────────────────────────

# Full LangGraph tracing. Disabled if keys are empty.
# SEC_RAG_LANGFUSE_PUBLIC_KEY=
# SEC_RAG_LANGFUSE_SECRET_KEY=
# SEC_RAG_LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
